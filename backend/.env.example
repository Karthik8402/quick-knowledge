# ══════════════════════════════════════════════════════════════
# Quick Knowledge Base — Environment Configuration
# ══════════════════════════════════════════════════════════════

# ── LLM Configuration ──
LLM_PROVIDER=google
LLM_MODEL=gemini-3.1-flash-lite
GOOGLE_API_KEY=your-google-api-key-here

# Optional providers (uncomment to use)
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-3.5-turbo
# OPENAI_API_KEY=your-openai-key-here

# LLM_PROVIDER=nvidia
# LLM_MODEL=minimaxai/minimax-m2.7
# NVIDIA_API_KEY=your-nvidia-api-key-here
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# LLM_TEMPERATURE=0
# LLM_TOP_P=1
# LLM_MAX_TOKENS=500
# LLM_TIMEOUT_SECONDS=45

# LLM_PROVIDER=groq
# LLM_MODEL=mixtral-8x7b-32768
# GROQ_API_KEY=your-groq-key-here

# ── Embedding Configuration ──
EMBEDDING_PROVIDER=google
EMBEDDING_MODEL=text-embedding-004

# ── Storage Backend ──
# "local"    → uses local filesystem + JSON registry (development)
# "supabase" → uses Supabase Storage + Postgres (production)
STORAGE_BACKEND=local

# ── Vector Store ──
# "chroma"   → local ChromaDB (development)
# "pgvector" → Supabase Postgres with pgvector (production)
VECTOR_STORE=chroma
CHROMA_PERSIST_DIR=./data/chroma

# Production example:
# STORAGE_BACKEND=supabase
# VECTOR_STORE=pgvector

# ── Local Storage (only used when STORAGE_BACKEND=local) ──
UPLOAD_DIR=./data/uploads
METADATA_DB_PATH=./data/document_registry.json
SQLITE_DB_PATH=./data/knowledge_base.db

# ── Supabase (required when STORAGE_BACKEND=supabase) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
SUPABASE_STORAGE_BUCKET=documents

# ── Authentication ──
# Set to "true" in production (requires Supabase Auth)
AUTH_ENABLED=false

# ── RAG Parameters ──
RAG_TOP_K=6
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=150

# ── Limits ──
MAX_UPLOAD_SIZE_MB=25
RATE_LIMIT=10/minute

# ── CORS (comma-separated origins) ──
# Allow both local and deployed frontend.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://intelligent-knowledge.vercel.app
